# ── Variables de entorno ─────────────────────────────────────────────────────
# Copiar este archivo como .env.local para desarrollo local.
# En producción, definir todas las variables en el panel de Vercel:
#   Vercel Dashboard → Project → Settings → Environment Variables

# ── Dashboard ────────────────────────────────────────────────────────────────
# PIN de acceso al dashboard de leads.
# Usar una cadena segura (mínimo 8 caracteres).
NEXT_PUBLIC_DASHBOARD_PIN=

# ── Formulario de contacto ───────────────────────────────────────────────────
# Access Key de Web3Forms (https://web3forms.com)
# Cuenta gratuita: 250 envíos/mes sin tarjeta de crédito.
NEXT_PUBLIC_WEB3FORMS_KEY=

# ── Analytics (opcional) ─────────────────────────────────────────────────────
# Website ID de Umami Cloud (https://umami.is)
# Sin cookies, GDPR-friendly. Dejar vacío para deshabilitar.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# ── CRM / Integraciones del cotizador ────────────────────────────────────────
# URL del webhook de Google Sheets para registrar leads.
# Obtener desde Google Apps Script → Implementar → Aplicación web.
GOOGLE_SHEETS_WEBHOOK_URL=

# Credenciales de Resend para email de confirmación (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
